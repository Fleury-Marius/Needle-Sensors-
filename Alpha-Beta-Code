#include <Wire.h> 
#include "VL6180X.h"

#define iic_add 0xa4 >> 1

// --- Alpha-Beta Filter Configuration ---
const float ALPHA = 0.35; // Position correction weight (0.0 to 1.0)
const float BETA  = 0.10; // Velocity correction weight (Keep low for stability)

// --- Sensor Orientation Adjuster ---
// If Filtered_Dist rises while Raw_Dist falls, change this to -1.0 to flip the IMU axis!
const float AXIS_INVERSION = 1.0; 

// --- Filter State Variables ---
float x_est = 0.0;    // Filtered Position (mm)
float v_est = 0.0;    // Filtered Velocity (mm/s)
unsigned long last_time = 0;
bool is_filter_initialized = false;

// Struct layout mapping directly to your GY-95T I2C register map
typedef struct __attribute__((packed)) {
  int16_t acc_x;   
  int16_t acc_y;   
  int16_t acc_z;   
  int16_t gyro_x;  
  int16_t gyro_y;  
  int16_t gyro_z;  
  int16_t roll;    
  int16_t pitch;   
  int16_t yaw;     
  uint8_t leve;    
  int16_t temp;    
  int16_t mag_x;   
  int16_t mag_y;   
  int16_t mag_z;   
} gy;

gy my_95Q;
unsigned int delay_t = 0;
byte ready_Ok = 0;

VL6180X sensor;

void setup() {
  Serial.begin(9600);
  Wire.begin();
  delay(100);

  // --- GY95T setup ---
  byte td = 1;
  iic_read(0x02, &td, 1);
  switch (td) {
    case 0: delay_t = 100; break;
    case 1: delay_t = 20; break;
    case 2: delay_t = 10; break;
    case 3: delay_t = 5; break;
  }
  delay(delay_t);
  attachInterrupt(0, Exti, RISING);

  // --- TOF050C (VL6180X) setup ---
  sensor.init();
  sensor.configureDefault();
  sensor.setTimeout(500);

  last_time = micros();
}

void loop() {
  unsigned char data[27] = {0};

  // --- Read GY95T ---
  iic_read(0x08, data, 27);
  memcpy(&my_95Q, data, 27);

  // 1. Calculate dynamic time step (dt) in fractional seconds
  unsigned long now = micros();
  float dt = (now - last_time) / 1000000.0;
  last_time = now;
  if (dt <= 0.0 || dt > 0.5) dt = 0.02; // Safeguard loop anomalies

  // 2. Convert raw IMU acceleration to mm/s^2 and apply inversion scale
  float a_meas = (float)my_95Q.acc_x * 0.5985 * AXIS_INVERSION; 

  // --- Dynamic Tilt Compensation ---
  // Read the onboard calculated pitch angle from the GY-95T registers and convert to radians
  float pitch_rad = (my_95Q.pitch / 100.0) * (PI / 180.0);
  // Subtract the component of gravity leaking into the acceleration axis
  float gravity_leakage = 9806.65 * sin(pitch_rad);
  float a_true = a_meas - gravity_leakage;

  // 3. PREDICT STEP: Kinematic equations of motion using true isolated acceleration
  float x_pred = x_est + (v_est * dt) + (0.5 * a_true * dt * dt);
  float v_pred = v_est + (a_true * dt);

  // --- Read TOF050C Laser ---
  uint16_t x_meas_raw = sensor.readRangeSingleMillimeters();
  
  if (!sensor.timeoutOccurred()) {
    float x_meas = (float)x_meas_raw;

    // Cleanly establish baseline tracking variables on the first good frame
    if (!is_filter_initialized) {
      x_est = x_meas;
      v_est = 0.0;
      is_filter_initialized = true;
    }

    // 4. UPDATE STEP: Calculate residual error and correct tracking parameters
    float residual = x_meas - x_pred;
    x_est = x_pred + (ALPHA * residual);
    v_est = v_pred + (BETA * residual); 
  } else {
    // If the laser gets temporarily blocked, drift-track via pure inertial physics predictions
    x_est = x_pred;
    v_est = v_pred;
  }

  ready_Ok = 0;

  // 5. Telemetry format optimized for the Arduino Serial Plotter
  Serial.print("Raw_Dist:");        Serial.print(x_meas_raw); Serial.print(",");
  Serial.print("Filtered_Dist:");   Serial.print(x_est);      Serial.print(",");
  Serial.print("Filtered_Veloc:");  Serial.println(v_est);

  delay(delay_t);
}

void Exti() {
  if (!ready_Ok) ready_Ok = 1;
}

void iic_read(unsigned char add, unsigned char *data, unsigned char len) {
  byte j = 0;
  Wire.beginTransmission(iic_add);
  Wire.write(add);
  Wire.endTransmission(false);
  Wire.requestFrom(iic_add, (int)len);
  for (j = 0; j < len; j++) *data++ = Wire.read();
}

void iic_write(char add, unsigned char data) {
  Wire.beginTransmission(iic_add);
  Wire.write((uint8_t)add);
  Wire.write((uint8_t)data);
  Wire.endTransmission();
}
