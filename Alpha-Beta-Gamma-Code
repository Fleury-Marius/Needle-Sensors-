#include <Wire.h> 
#include "VL6180X.h"

#define iic_add 0xa4 >> 1

// --- Alpha-Beta-Gamma Filter Configuration ---
// Adjust these weights to fine-tune your circuit's response:
const float ALPHA = 0.45; // Smooths position tracking (higher = reacts faster to laser)
const float BETA  = 0.25; // Tracks velocity calculation
const float GAMMA = 0.05; // Learns and eliminates sensor drift/tilt bias over time

// --- Filter State Variables ---
float x_est = 0.0;    // Filtered Position (mm)
float v_est = 0.0;    // Filtered Velocity (mm/s)
float a_bias = 0.0;   // Dynamically learned accelerometer offset
unsigned long last_time = 0;
bool is_filter_initialized = false;

// Struct layout mapping directly to GY-95T memory map
typedef struct __attribute__((packed)) {
  int16_t acc_x;   
  int16_t acc_y;   
  int16_t acc_z;   
  int16_t gyro_x;  
  int16_t gyro_y;  
  int16_t gyro_z;  
  int16_t roll;    
  int16_t pitch;   
  int16_t yaw;     
  uint8_t leve;    
  int16_t temp;    
  int16_t mag_x;   
  int16_t mag_y;   
  int16_t mag_z;   
} gy;

unsigned char Re_buf;
unsigned char sign = 0;
gy my_95Q;
unsigned int delay_t = 0;
byte ready_Ok = 0;

VL6180X sensor;

void setup() {
  Serial.begin(9600);
  Wire.begin();
  delay(100);

  // --- GY95T setup ---
  byte td = 1;
  iic_read(0x02, &td, 1);
  switch (td) {
    case 0: delay_t = 100; break;
    case 1: delay_t = 20; break;
    case 2: delay_t = 10; break;
    case 3: delay_t = 5; break;
  }
  delay(delay_t);
  attachInterrupt(0, Exti, RISING);

  // --- TOF050C (VL6180X) setup ---
  sensor.init();
  sensor.configureDefault();
  sensor.setTimeout(500);

  last_time = micros();
}

void loop() {
  unsigned char data[27] = {0};

  // --- Read GY95T (accel/gyro/mag) ---
  iic_read(0x08, data, 27);
  memcpy(&my_95Q, data, 27);

  // 1. Calculate dynamic time step delta (dt) in fractional seconds
  unsigned long now = micros();
  float dt = (now - last_time) / 1000000.0;
  last_time = now;
  if (dt <= 0.0) dt = 0.001; // Safety threshold to prevent division by zero

  // 2. Convert raw IMU acceleration to standard mm/s^2 
  // (Assumes physical target movement aligns with the sensor's X axis)
  float a_meas = (float)my_95Q.acc_x * 0.5985; 
  float a_true = a_meas - a_bias;

  // 3. PREDICT STEP: Project position and speed forward using real-world physics
  float x_pred = x_est + (v_est * dt) + (0.5 * a_true * dt * dt);
  float v_pred = v_est + (a_true * dt);

  // --- Read TOF050C Laser (distance) ---
  uint16_t x_meas_raw = sensor.readRangeSingleMillimeters();
  
  // Verify sensor operational readiness (checks for frame timeouts or blocks)
  if (!sensor.timeoutOccurred()) {
    float x_meas = (float)x_meas_raw;

    // Seed the filter parameters cleanly on your very first valid reading
    if (!is_filter_initialized) {
      x_est = x_meas;
      v_est = 0.0;
      a_bias = 0.0;
      is_filter_initialized = true;
    }

    // 4. UPDATE STEP: Calculate residual error matrix and scale filter responses
    float residual = x_meas - x_pred;
    x_est  = x_pred + (ALPHA * residual);
    v_est  = v_pred + ((BETA * residual) / dt);
    a_bias = a_bias + ((2.0 * GAMMA * residual) / (dt * dt));
  } else {
    // Laser stream is interrupted; seamlessly sustain tracking on IMU kinematics calculations
    x_est = x_pred;
    v_est = v_pred;
  }

  // Reset internal pin interrupt flag
  ready_Ok = 0;

  // 5. Telemetry output stream tailored cleanly for Arduino Serial Plotter
  Serial.print("Raw_Dist:");        Serial.print(x_meas_raw); Serial.print(",");
  Serial.print("Filtered_Dist:");   Serial.print(x_est);      Serial.print(",");
  Serial.print("Filtered_Veloc:");  Serial.println(v_est);

  delay(delay_t);
}

void Exti() {
  if (!ready_Ok) ready_Ok = 1;
}

void iic_read(unsigned char add, unsigned char *data, unsigned char len) {
  byte j = 0;
  Wire.beginTransmission(iic_add);
  Wire.write(add);
  Wire.endTransmission(false);
  Wire.requestFrom(iic_add, (int)len);
  for (j = 0; j < len; j++) *data++ = Wire.read();
}

void iic_write(char add, unsigned char data) {
  Wire.beginTransmission(iic_add);
  Wire.write((uint8_t)add);
  Wire.write((uint8_t)data);
  Wire.endTransmission();
}
